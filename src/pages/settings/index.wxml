<view wx:if="{{!ready}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载账号…</view>
</view>

<view wx:else class="page">
  <view class="settings-content">
    <view class="profile-card {{isAdmin ? 'profile-card--accent' : ''}}">
      <image wx:if="{{avatarUrl}}" class="profile-avatar" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="profile-avatar-fallback">{{avatarInitial}}</view>
      <view class="profile-main">
        <view class="profile-name">{{displayName}}</view>
        <view class="profile-role">{{isAdmin ? '管理员' : '普通用户'}}</view>
      </view>
    </view>

    <view class="settings-section">
      <view class="settings-section__title">账号</view>
      <view class="settings-list">
        <view
          class="settings-item"
          hover-class="settings-item--hover"
          hover-stay-time="80"
          bindtap="handleCopyOpenIdTap"
        >
          <view class="settings-item__label-group"><app-icon name="copy" size="25" /><text class="settings-item__label">我的 OpenID</text></view>
          <view class="settings-item__right">
            <text class="settings-item__value">{{openidLabel}}</text>
            <view class="settings-item__arrow"><app-icon name="chevron-right" size="26" /></view>
          </view>
        </view>
        <view
          class="settings-item"
          hover-class="settings-item--hover"
          hover-stay-time="80"
          bindtap="handleLogoutTap"
        >
          <view class="settings-item__label-group"><app-icon name="log-out-danger" size="25" /><text class="settings-item__label settings-item__label--danger">退出登录</text></view>
          <view class="settings-item__arrow"><app-icon name="chevron-right" size="26" /></view>
        </view>
      </view>
    </view>

    <view class="settings-section">
      <view class="settings-section__title">通用</view>
      <view class="settings-list">
        <view
          class="settings-item"
          hover-class="settings-item--hover"
          hover-stay-time="80"
          bindtap="handleAboutTap"
        >
          <view class="settings-item__label-group"><app-icon name="info" size="25" /><text class="settings-item__label">关于</text></view>
          <view class="settings-item__right">
            <text class="settings-item__value">{{icpNumber}}</text>
            <view class="settings-item__arrow"><app-icon name="chevron-right" size="26" /></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
