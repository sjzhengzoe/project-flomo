<view wx:if="{{loading}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载分类…</view>
</view>

<view wx:else class="page">
    <view class="record-overview">
      <view class="record-overview__title">{{categoryId ? '编辑分类' : '新增分类'}}</view>
      <view class="record-overview__stats">
        <view class="record-overview__stat">
          <view class="record-overview__value">{{categoryId ? '已创建' : '待保存'}}</view>
          <view class="record-overview__label">状态</view>
        </view>
        <view class="record-overview__stat">
          <view class="record-overview__value">{{fields.length}}</view>
          <view class="record-overview__label">属性</view>
        </view>
      </view>
    </view>

    <view class="form-card">
      <view class="field">
        <view class="field__label">分类名称</view>
        <input
          class="field__input"
          value="{{name}}"
          maxlength="40"
          placeholder="例如：T 恤、长裤、短上衣"
          bindinput="handleNameInput"
        />
      </view>

      <view class="preset-section">
        <view class="field__label">快速添加属性</view>
        <view class="preset-row">
          <view class="preset-button" data-preset="upper" bindtap="handlePreset"><app-icon name="plus" size="20" /><text>上装预设</text></view>
          <view class="preset-button" data-preset="lower" bindtap="handlePreset"><app-icon name="plus" size="20" /><text>下装预设</text></view>
          <view class="preset-button preset-button--muted" bindtap="handleClearFields"><app-icon name="eraser" size="20" /><text>清空</text></view>
        </view>
      </view>
    </view>

    <view class="attribute-section">
      <view class="section-header">
        <view>
          <view class="section-title">填写属性</view>
          <view class="section-desc">衣物选择该分类后，会自动显示这些输入项。</view>
        </view>
        <view class="section-add" bindtap="handleAddField"><app-icon name="plus-white" size="20" /><text>属性</text></view>
      </view>

      <view wx:if="{{fields.length === 0}}" class="attribute-empty">暂无属性，也可以保存为空白分类。</view>
      <view wx:else class="attribute-list">
        <view wx:for="{{fields}}" wx:key="index" class="attribute-row">
          <input
            class="attribute-input"
            value="{{item.name}}"
            maxlength="40"
            placeholder="属性名称"
            data-index="{{index}}"
            bindinput="handleFieldInput"
          />
          <view class="attribute-tools">
            <view
              class="tool {{index === 0 ? 'tool--disabled' : ''}}"
              data-index="{{index}}"
              data-direction="-1"
              bindtap="handleMoveField"
            ><app-icon name="arrow-up" size="22" /></view>
            <view
              class="tool {{index === fields.length - 1 ? 'tool--disabled' : ''}}"
              data-index="{{index}}"
              data-direction="1"
              bindtap="handleMoveField"
            ><app-icon name="arrow-down" size="22" /></view>
            <view class="tool tool--danger" role="button" aria-label="删除属性" data-index="{{index}}" bindtap="handleRemoveField"><app-icon name="x-danger" size="22" /></view>
          </view>
        </view>
      </view>
    </view>

    <view class="footer-actions">
      <button class="save-button" loading="{{saving}}" disabled="{{saving || deleting}}" bindtap="handleSave">保存分类</button>
      <button wx:if="{{categoryId}}" class="delete-button" loading="{{deleting}}" disabled="{{saving || deleting}}" bindtap="handleDelete"><app-icon name="trash-2-danger" size="25" /><text>删除分类</text></button>
    </view>
</view>
