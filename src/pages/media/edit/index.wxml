<view wx:if="{{loading}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载影视资料…</view>
</view>

<view wx:else class="page">
  <view class="record-overview">
    <view class="record-overview__title">{{id ? '编辑影视' : '新增影视'}}</view>
    <view class="record-overview__stats">
      <view class="record-overview__stat">
        <view class="record-overview__value">{{mediaTypes[mediaTypeIndex]}}</view>
        <view class="record-overview__label">分类</view>
      </view>
      <view class="record-overview__stat">
        <view class="record-overview__value">{{isAudio ? (watchStatus === 'planned' ? '想听' : watchStatus === 'in_progress' ? '在听' : '听过') : (watchStatus === 'planned' ? '想看' : watchStatus === 'in_progress' ? (isEpisodic ? '在看' : '正在看') : (isEpisodic ? '看过' : '已阅'))}}</view>
        <view class="record-overview__label">状态</view>
      </view>
    </view>
  </view>
  <view class="form-card">
    <view class="field">
      <view class="field-label">名称</view>
      <input class="field-input" value="{{title}}" maxlength="120" placeholder="输入影视剧、动漫或小说名称" bindinput="handleTitleInput" />
    </view>
    <view class="field">
      <view class="field-label">分类</view>
      <picker mode="selector" range="{{mediaTypes}}" value="{{mediaTypeIndex}}" bindchange="handleTypeChange">
        <view class="picker-value"><text>{{mediaTypes[mediaTypeIndex]}}</text><app-icon name="chevron-right" size="28" /></view>
      </picker>
    </view>
    <view class="field">
      <view class="field-label">状态</view>
      <view class="status-options">
        <view class="status-option {{watchStatus === 'planned' ? 'status-option--active' : ''}}" data-status="planned" bindtap="handleStatusTap">{{isAudio ? '想听' : '想看'}}</view>
        <view class="status-option {{watchStatus === 'in_progress' ? 'status-option--active' : ''}}" data-status="in_progress" bindtap="handleStatusTap">{{isAudio ? '在听' : (isEpisodic ? '在看' : '正在看')}}</view>
        <view class="status-option {{watchStatus === 'completed' ? 'status-option--active' : ''}}" data-status="completed" bindtap="handleStatusTap">{{isAudio ? '听过' : (isEpisodic ? '看过' : '已阅')}}</view>
      </view>
    </view>
    <view class="field field--switch">
      <view>
        <view class="field-label field-label--primary">{{isAudio ? '值得重听' : '值得重温'}}</view>
        <view class="field-help">以后想再次完整{{isAudio ? '收听' : '体验'}}这部作品</view>
      </view>
      <switch checked="{{isRevisitable}}" color="#111111" bindchange="handleRevisitableChange" />
    </view>
    <view class="field">
      <view class="field-label">平台/来源（必填，可多选）</view>
      <view class="field-help platform-help">不知道具体来源时选择“待定”；待定不能和其他平台同时选择</view>
      <checkbox-group class="platform-options" bindchange="handlePlatformsChange">
        <label wx:for="{{platformOptions}}" wx:key="name" class="platform-option">
          <checkbox value="{{item.name}}" checked="{{item.checked}}" color="#111111" />
          <text>{{item.name}}</text>
        </label>
      </checkbox-group>
    </view>
  </view>
  <button class="save-button" loading="{{saving}}" disabled="{{saving || deleting}}" bindtap="handleSave">保存</button>
  <button wx:if="{{id}}" class="delete-button" loading="{{deleting}}" disabled="{{saving || deleting}}" bindtap="handleDelete"><app-icon name="trash-2-danger" size="25" /><text>删除</text></button>
</view>
