<view wx:if="{{loading && !hasLoaded}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载分类…</view>
</view>

<view wx:else class="page">
  <view class="overview">
    <view class="overview__topline">
      <view class="overview__title">管理影视分类</view>
      <button class="overview__add" bindtap="handleAdd"><app-icon name="plus-white" size="22" /><text>新增</text></button>
    </view>
    <view class="overview__stats">
      <view class="overview-stat">
        <view class="overview-stat__value">{{categories.length}}</view>
        <view class="overview-stat__label">分类</view>
      </view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="state">
    <view>{{errorMessage}}</view>
    <button class="retry-button" bindtap="handleRetry">重试</button>
  </view>
  <view wx:elif="{{categories.length === 0}}" class="state">还没有分类</view>
  <view wx:else class="category-list">
    <view wx:for="{{categories}}" wx:key="id" class="category-card" data-id="{{item.id}}" bindtap="handleEdit">
      <view class="category-card__main">
        <view class="category-card__name">{{item.name}}</view>
        <view class="category-card__fields">点击修改分类名称</view>
      </view>
      <view class="category-card__sort">
        <view class="sort-control {{index === 0 ? 'sort-control--disabled' : ''}}" data-index="{{index}}" data-direction="-1" catchtap="handleMove"><app-icon name="arrow-up" size="24" /></view>
        <view class="sort-control {{index === categories.length - 1 ? 'sort-control--disabled' : ''}}" data-index="{{index}}" data-direction="1" catchtap="handleMove"><app-icon name="arrow-down" size="24" /></view>
      </view>
      <view class="category-card__arrow"><app-icon name="chevron-right" size="28" /></view>
    </view>
  </view>
</view>
