<view wx:if="{{loading && !hasLoaded}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载影视清单…</view>
</view>

<view wx:else class="page">
  <view class="side-tabs">
    <view
      wx:for="{{mediaTypes}}"
      wx:key="*this"
      class="side-tab {{activeType === item ? 'side-tab--active' : ''}}"
      data-type="{{item}}"
      bindtap="handleTypeTap"
    >{{item}}</view>
  </view>

  <view class="content">
    <view class="app-overview media-overview">
      <view class="app-overview__topline">
        <view class="app-overview__title-group">
          <view class="app-overview__title">{{activeType || '影视清单'}}</view>
          <view wx:if="{{canWrite}}" class="media-manage" bindtap="handleManageCategories">
            <app-icon name="settings-2" size="22" /><text>管理分类</text>
          </view>
        </view>
        <button wx:if="{{canWrite}}" class="app-overview__action" bindtap="handleAdd"><app-icon name="plus-white" size="22" /><text>新增</text></button>
      </view>
      <view class="app-overview__stats">
        <view class="app-overview__stat">
          <view class="app-overview__value">{{totalItems}}</view>
          <view class="app-overview__label">当前作品</view>
        </view>
        <view class="app-overview__stat">
          <view class="app-overview__value">{{mediaTypes.length}}</view>
          <view class="app-overview__label">内容分类</view>
        </view>
      </view>
    </view>

    <view class="favorite-search">
      <input
        class="favorite-search__input"
        value="{{keyword}}"
        placeholder="搜索作品名"
        confirm-type="search"
        bindinput="handleKeywordInput"
        bindconfirm="handleSearch"
      />
      <view class="favorite-search__button" bindtap="handleSearch">搜索</view>
    </view>

    <scroll-view class="status-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="status-list">
        <view class="status-chip {{statusFilter === 'all' ? 'status-chip--active' : ''}}" data-status="all" bindtap="handleStatusTap">全部</view>
        <view class="status-chip {{statusFilter === 'planned' ? 'status-chip--active' : ''}}" data-status="planned" bindtap="handleStatusTap">{{isAudio ? '想听' : '想看'}}</view>
        <view class="status-chip {{statusFilter === 'in_progress' ? 'status-chip--active' : ''}}" data-status="in_progress" bindtap="handleStatusTap">{{isAudio ? '在听' : (isEpisodic ? '在看' : '正在看')}}</view>
        <view class="status-chip {{statusFilter === 'completed' ? 'status-chip--active' : ''}}" data-status="completed" bindtap="handleStatusTap">{{isAudio ? '听过' : (isEpisodic ? '看过' : '已阅')}}</view>
        <view class="status-chip {{statusFilter === 'revisitable' ? 'status-chip--active' : ''}}" data-status="revisitable" bindtap="handleStatusTap">{{isAudio ? '值得重听' : '值得重温'}}</view>
      </view>
    </scroll-view>

    <view wx:if="{{canReorder}}" class="sort-hint">按住拖拽图标，拖到目标条目即可交换位置</view>

    <view wx:if="{{contentLoading}}" class="content-loading">
      <view class="content-loading__spinner" />
      <view class="content-loading__text">正在加载内容…</view>
    </view>
    <view wx:elif="{{errorMessage}}" class="state">{{errorMessage}}</view>
    <view wx:elif="{{items.length === 0}}" class="state">{{appliedKeyword ? '没有找到相关作品' : '暂无内容'}}</view>
    <view wx:else class="media-list">
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="media-card js-sortable-media {{draggingIndex === index ? 'media-card--dragging' : ''}} {{dragTargetIndex === index && draggingIndex !== index ? 'media-card--drop-target' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleEdit"
      >
        <view class="media-card__content">
          <image wx:if="{{item.cover_url}}" class="media-card__cover" src="{{item.cover_url}}" mode="aspectFill" lazy-load />
          <view class="media-card__main">
            <view class="media-card__top">
              <view class="media-card__title">{{item.title}}</view>
              <view class="status-badge status-badge--{{item.watch_status}}">
                {{isAudio ? (item.watch_status === 'planned' ? '想听' : item.watch_status === 'in_progress' ? '在听' : '听过') : (item.watch_status === 'planned' ? '想看' : item.watch_status === 'in_progress' ? (isEpisodic ? '在看' : '正在看') : (isEpisodic ? '看过' : '已阅'))}}
              </view>
            </view>
            <view wx:if="{{item.platforms.length}}" class="platforms">
              <text wx:for="{{item.platforms}}" wx:key="*this" class="platform-tag">{{item}}</text>
            </view>
            <view wx:if="{{isEpisodic}}" class="episode-stats">
              <text>{{item.season_count || 0}} 季</text>
              <text>·</text>
              <text>{{item.episode_count || 0}} 集</text>
              <text wx:if="{{item.favorite_episode_count}}">· <text class="episode-favorite-count__heart">♥</text> {{item.favorite_episode_count}} 集</text>
            </view>
            <view
              class="revisit-tag {{item.is_revisitable ? 'revisit-tag--active' : ''}}"
              data-id="{{item.id}}"
              catchtap="handleToggleRevisitable"
            >↻ {{isAudio ? '值得重听' : '值得重温'}}</view>
          </view>
        </view>
        <view wx:if="{{canReorder}}" class="drag-row">
          <view
            class="drag-handle {{sorting ? 'drag-handle--disabled' : ''}}"
            data-index="{{index}}"
            aria-label="拖拽调整影视位置"
            catchlongpress="handleDragStart"
            catchtouchmove="handleDragMove"
            catchtouchend="handleDragEnd"
            catchtouchcancel="handleDragCancel"
          ><app-icon name="grip-vertical" size="30" /></view>
        </view>
      </view>
      <view wx:if="{{hasMore && !loadingMore}}" class="load-more-state">继续上滑加载更多</view>
    </view>

  </view>
</view>
