<view wx:if="{{loading && !hasLoaded}}" class="fullscreen-loading"><view class="fullscreen-loading__spinner"/><view class="fullscreen-loading__text">正在加载场景…</view></view>
<view wx:else class="page">
  <view class="overview"><view class="overview__topline"><view class="overview__title">管理用餐场景</view><button class="overview__add" bindtap="handleAdd"><app-icon name="plus-white" size="22"/><text>新增</text></button></view><view class="overview__stats"><view class="overview-stat"><view class="overview-stat__value">{{scenes.length}}</view><view class="overview-stat__label">场景</view></view></view></view>
  <view wx:if="{{errorMessage}}" class="state">{{errorMessage}}</view>
  <view wx:elif="{{scenes.length === 0}}" class="state">还没有场景</view>
  <view wx:else class="category-list"><view wx:for="{{scenes}}" wx:key="id" class="category-card" data-id="{{item.id}}" bindtap="handleEdit"><view class="category-card__main"><view class="category-card__name">{{item.name}}</view><view class="category-card__fields">点击修改场景名称</view></view><view class="category-card__sort"><view class="sort-control {{index === 0 ? 'sort-control--disabled' : ''}}" data-index="{{index}}" data-direction="-1" catchtap="handleMove"><app-icon name="arrow-up" size="24"/></view><view class="sort-control {{index === scenes.length - 1 ? 'sort-control--disabled' : ''}}" data-index="{{index}}" data-direction="1" catchtap="handleMove"><app-icon name="arrow-down" size="24"/></view></view><view class="category-card__arrow"><app-icon name="chevron-right" size="28"/></view></view></view>
</view>
