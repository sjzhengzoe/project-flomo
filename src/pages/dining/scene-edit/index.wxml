<view wx:if="{{loading}}" class="fullscreen-loading"><view class="fullscreen-loading__spinner"/><view class="fullscreen-loading__text">正在加载场景…</view></view>
<view wx:else class="page"><view class="record-overview"><view class="record-overview__title">{{sceneId ? '编辑场景' : '新增场景'}}</view><view class="record-overview__stats"><view class="record-overview__stat"><view class="record-overview__value">{{sceneId ? '已创建' : '待保存'}}</view><view class="record-overview__label">状态</view></view></view></view><view class="form-card"><view class="field"><view class="field__label">场景名称</view><input class="field__input" value="{{name}}" maxlength="40" placeholder="例如：工作餐、约会、朋友聚餐" bindinput="handleNameInput"/></view></view><view class="footer-actions"><button class="save-button" loading="{{saving}}" disabled="{{saving || deleting}}" bindtap="handleSave">保存场景</button><button wx:if="{{sceneId}}" class="delete-button" loading="{{deleting}}" disabled="{{saving || deleting}}" bindtap="handleDelete"><app-icon name="trash-2-danger" size="25"/><text>删除场景</text></button></view></view>
