<view wx:if="{{loading && !hasLoaded}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载店铺…</view>
</view>

<view wx:else class="page">
  <view class="side-tabs">
    <scroll-view class="side-tabs__list" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:for="{{scenes}}" wx:key="id" class="side-tab {{activeSceneId === item.id ? 'side-tab--active' : ''}}" data-id="{{item.id}}" bindtap="handleSceneTap">{{item.name}}</view>
    </scroll-view>
    <view wx:if="{{canWrite}}" class="side-tabs__edit" role="button" aria-label="编辑场景" bindtap="handleManageScenes"><view class="side-tabs__edit-button"><app-icon name="pencil" size="26" /></view></view>
  </view>
  <view class="content">
  <view class="app-overview dining-overview">
    <view class="app-overview__topline">
      <view class="app-overview__title">{{activeSceneName}}</view>
      <button wx:if="{{canWrite}}" class="app-overview__action" bindtap="handleAdd"><app-icon name="plus-white" size="22" /><text>新增</text></button>
    </view>
    <view class="app-overview__stats">
      <view class="app-overview__stat">
        <view class="app-overview__value">{{items.length}}</view>
        <view class="app-overview__label">店铺</view>
      </view>
      <view class="app-overview__stat">
        <view class="app-overview__value">{{takeoutCount}}</view>
        <view class="app-overview__label">可外卖</view>
      </view>
      <view class="app-overview__stat">
        <view class="app-overview__value">{{dineInCount}}</view>
        <view class="app-overview__label">可堂食</view>
      </view>
    </view>
  </view>
  <view wx:if="{{errorMessage}}" class="state">{{errorMessage}}</view>
  <view wx:elif="{{items.length === 0}}" class="state">还没有店铺记录</view>
  <view wx:else class="place-list">
    <view wx:for="{{items}}" wx:key="id" class="place-card" data-id="{{item.id}}" bindtap="handleEdit">
      <view class="place-top">
        <view class="place-name">{{item.name}}</view>
        <view class="mode-tags">
          <text wx:if="{{item.supportsTakeout}}" class="mode-tag">可外卖</text>
          <text wx:if="{{item.supportsDineIn}}" class="mode-tag">可堂食</text>
        </view>
      </view>
      <view wx:if="{{item.menu_items.length}}" class="menu-items">
        <text wx:for="{{item.menu_items}}" wx:key="*this" class="menu-item">{{item}}</text>
      </view>
      <view wx:else class="no-menu">暂未记录菜品</view>
    </view>
  </view>
  </view>
</view>
