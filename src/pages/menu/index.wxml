<view wx:if="{{loading}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载菜单…</view>
</view>

<view wx:else class="page">
  <scroll-view class="side-tabs" scroll-y enhanced show-scrollbar="{{false}}">
    <view
      class="side-tab {{activeCategoryId === '' ? 'side-tab--active' : ''}}"
      data-id=""
      bindtap="handleCategoryTap"
    >全部</view>
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="side-tab {{activeCategoryId === item.id ? 'side-tab--active' : ''}}"
      data-id="{{item.id}}"
      bindtap="handleCategoryTap"
    >{{item.name}}</view>
  </scroll-view>

  <view class="content">
    <view class="app-overview menu-overview">
      <view class="app-overview__topline">
        <view class="app-overview__title-group">
          <view class="app-overview__title">我的菜单</view>
          <view class="app-overview__link" bindtap="handlePrintTap">
            <app-icon name="printer" size="22" />
            <text>选四张打印</text>
            <view class="app-overview__link-arrow"><app-icon name="chevron-right" size="24" /></view>
          </view>
        </view>
        <button wx:if="{{canWrite}}" class="app-overview__action" bindtap="handleAddTap"><app-icon name="plus-white" size="22" /><text>新增</text></button>
      </view>
      <view class="app-overview__stats">
        <view class="app-overview__stat">
          <view class="app-overview__value">{{dishes.length}}</view>
          <view class="app-overview__label">当前菜品</view>
        </view>
        <view class="app-overview__stat">
          <view class="app-overview__value">{{categories.length}}</view>
          <view class="app-overview__label">分类</view>
        </view>
      </view>
    </view>

    <view wx:if="{{canReorder}}" class="sort-hint">按住卡片右下角的拖拽图标，拖到目标菜品即可交换位置</view>

    <view wx:if="{{contentLoading}}" class="content-loading">
      <view class="content-loading__spinner" />
      <view class="content-loading__text">正在加载菜品…</view>
    </view>
    <view wx:elif="{{errorMessage}}" class="state-block">
      <view>{{errorMessage}}</view>
      <button class="retry-button" bindtap="handleRetry">重试</button>
    </view>
    <view wx:elif="{{dishes.length === 0}}" class="state-block">暂无菜品</view>

    <view wx:else class="dish-list">
      <view
        wx:for="{{dishes}}"
        wx:key="id"
        class="dish-card js-sortable-dish {{draggingIndex === index ? 'dish-card--dragging' : ''}} {{dragTargetIndex === index && draggingIndex !== index ? 'dish-card--drop-target' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleDishTap"
      >
        <view class="dish-card__image-wrap">
          <image class="dish-card__image" src="{{item.thumbnail_url || item.image_url}}" mode="aspectFit" lazy-load />
        </view>
        <view class="dish-card__body">
          <view class="dish-card__name">{{item.name}}</view>
          <view class="dish-card__category">{{item.category && item.category.name ? item.category.name : '未分类'}}</view>
          <view wx:if="{{canReorder}}" class="dish-card__tools">
            <view
              class="drag-handle {{sorting ? 'drag-handle--disabled' : ''}}"
              data-index="{{index}}"
              aria-label="拖拽调整菜品位置"
              catchlongpress="handleDragStart"
              catchtouchmove="handleDragMove"
              catchtouchend="handleDragEnd"
              catchtouchcancel="handleDragCancel"
            ><app-icon name="grip-vertical" size="30" /></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
