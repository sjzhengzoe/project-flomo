<view wx:if="{{loading}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载场景…</view>
</view>

<view wx:else class="page">
  <view class="record-overview">
    <view class="record-overview__title">{{id ? '编辑场景' : '新增场景'}}</view>
    <view class="record-overview__stats">
      <view class="record-overview__stat">
        <view class="record-overview__value">{{id ? itemCount : '待保存'}}</view>
        <view class="record-overview__label">{{id ? '物品' : '状态'}}</view>
      </view>
      <view wx:if="{{id}}" class="record-overview__stat">
        <view class="record-overview__value">{{groupCount}}</view>
        <view class="record-overview__label">分组</view>
      </view>
    </view>
  </view>
  <view class="form-card">
    <view class="field">
      <view class="field__label">场景名称</view>
      <input class="field__input" value="{{name}}" maxlength="80" placeholder="例如：成都三日游" bindinput="handleNameInput" />
    </view>
  </view>
  <view class="footer-actions">
    <button class="save-button" loading="{{saving}}" disabled="{{saving || deleting}}" bindtap="handleSave">{{id ? '保存场景' : '创建场景'}}</button>
    <button wx:if="{{id}}" class="delete-button" loading="{{deleting}}" disabled="{{saving || deleting}}" bindtap="handleDelete"><app-icon name="trash-2-danger" size="25" /><text>删除场景</text></button>
  </view>
  <operation-loading visible="{{saving || deleting}}" text="{{deleting ? '正在删除场景…' : id ? '正在保存场景…' : '正在创建场景…'}}" />
</view>
