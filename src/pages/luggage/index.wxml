<view wx:if="{{loading && !hasLoaded}}" class="fullscreen-loading">
  <view class="fullscreen-loading__spinner" />
  <view class="fullscreen-loading__text">正在加载行李清单…</view>
</view>

<view wx:else class="page">
  <view class="scene-tabs">
    <scroll-view class="scene-tabs__list" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:for="{{scenes}}" wx:key="id" class="scene-tab {{activeSceneId === item.id ? 'scene-tab--active' : ''}}" data-id="{{item.id}}" bindtap="handleSceneTap">{{item.name}}</view>
    </scroll-view>
    <view wx:if="{{canWrite}}" class="scene-add-fixed" role="button" aria-label="新增场景" bindtap="handleAddScene">
      <view class="scene-add-fixed__button"><app-icon name="plus" size="27" /></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{!activeScene}}" class="empty-state">
      <view>还没有行李场景</view>
      <button wx:if="{{canWrite}}" class="primary-button" bindtap="handleAddScene">新增第一个场景</button>
    </view>
    <block wx:else>
      <view class="app-overview luggage-overview">
        <view class="app-overview__topline">
          <view class="app-overview__title-group">
            <view class="luggage-title-row">
              <view class="app-overview__title">{{activeScene.name}}</view>
            </view>
          </view>
          <view wx:if="{{canWrite}}" class="scene-overview-actions">
            <view
              class="scene-icon-button scene-icon-button--rename"
              role="button"
              aria-label="修改场景名称"
              bindtap="handleRenameScene"
            >
              <app-icon name="pencil" size="25" />
            </view>
            <view
              class="scene-icon-button scene-icon-button--delete"
              role="button"
              aria-label="删除场景"
              bindtap="handleDeleteScene"
            >
              <app-icon name="trash-2-danger" size="27" />
            </view>
          </view>
        </view>
        <view class="app-overview__stats">
          <view class="app-overview__stat">
            <view class="app-overview__value">{{activeGroupCount}}</view>
            <view class="app-overview__label">携带层级</view>
          </view>
          <view class="app-overview__stat">
            <view class="app-overview__value">{{activeItemCount}}</view>
            <view class="app-overview__label">物品</view>
          </view>
        </view>
      </view>

      <view wx:if="{{canWrite}}" class="scene-toolbar">
        <view class="scene-toolbar__action {{sortEditing ? 'scene-toolbar__action--active' : ''}}" bindtap="handleSortEditingToggle">
          <app-icon name="settings-2" size="22" />
          <text>{{sortEditing ? '完成排序' : '编辑排序'}}</text>
        </view>
        <view class="scene-toolbar__action" bindtap="handleAddGroup">
          <app-icon name="plus" size="23" />
          <text>新增分组</text>
        </view>
      </view>

      <view class="group-list">
        <view wx:for="{{activeScene.groups}}" wx:for-item="group" wx:for-index="groupIndex" wx:key="id" class="group-card">
          <view class="group-header">
            <view class="group-header__main">
              <view class="group-title">{{group.name}}</view>
              <view class="group-count">{{group.items.length}} 件物品</view>
            </view>
            <view wx:if="{{canWrite}}" class="inline-icon-actions">
              <block wx:if="{{sortEditing}}">
                <view class="inline-icon-button {{groupIndex === 0 ? 'inline-icon-button--disabled' : ''}}" data-index="{{groupIndex}}" data-direction="-1" catchtap="handleGroupMove"><app-icon name="arrow-up" size="24" /></view>
                <view class="inline-icon-button {{groupIndex === activeScene.groups.length - 1 ? 'inline-icon-button--disabled' : ''}}" data-index="{{groupIndex}}" data-direction="1" catchtap="handleGroupMove"><app-icon name="arrow-down" size="24" /></view>
              </block>
              <view
                class="inline-icon-button"
                role="button"
                aria-label="修改层级名称"
                data-id="{{group.id}}"
                data-name="{{group.name}}"
                bindtap="handleRenameGroup"
              >
                <app-icon name="pencil" size="24" />
              </view>
              <view
                class="inline-icon-button inline-icon-button--delete"
                role="button"
                aria-label="删除层级"
                data-id="{{group.id}}"
                bindtap="handleDeleteGroup"
              >
                <app-icon name="trash-2-danger" size="24" />
              </view>
            </view>
          </view>
          <view class="luggage-items">
            <view
              wx:for="{{group.items}}"
              wx:for-item="luggageItem"
              wx:for-index="itemIndex"
              wx:key="id"
              class="luggage-item"
              data-id="{{luggageItem.id}}"
              data-group-id="{{group.id}}"
              data-name="{{luggageItem.name}}"
              bindtap="handleItemTap"
            >
              <view class="luggage-item__marker">{{itemIndex + 1}}</view>
              <view class="luggage-item__name">{{luggageItem.name}}</view>
              <view wx:if="{{canWrite}}" class="inline-icon-actions">
                <block wx:if="{{sortEditing}}">
                  <view class="inline-icon-button {{itemIndex === 0 ? 'inline-icon-button--disabled' : ''}}" data-group-id="{{group.id}}" data-index="{{itemIndex}}" data-direction="-1" catchtap="handleItemMove"><app-icon name="arrow-up" size="23" /></view>
                  <view class="inline-icon-button {{itemIndex === group.items.length - 1 ? 'inline-icon-button--disabled' : ''}}" data-group-id="{{group.id}}" data-index="{{itemIndex}}" data-direction="1" catchtap="handleItemMove"><app-icon name="arrow-down" size="23" /></view>
                </block>
                <view
                  class="item-delete-button"
                  role="button"
                  aria-label="删除物品"
                  data-id="{{luggageItem.id}}"
                  catchtap="handleDeleteItem"
                >
                  <app-icon name="trash-2-danger" size="24" />
                </view>
              </view>
            </view>
            <view wx:if="{{group.items.length === 0}}" class="items-empty">这个分组还没有物品</view>
          </view>
          <view wx:if="{{canWrite}}" class="add-item" data-group-id="{{group.id}}" bindtap="handleAddItem"><app-icon name="plus" size="22" /><text>添加物品</text></view>
        </view>
      </view>
    </block>
  </scroll-view>

  <operation-loading
    visible="{{ordering || savingItem || savingGroup || savingScene || editing || deleting}}"
    text="{{deleting ? deletingLabel : editing ? editingLabel : savingItem ? '正在添加物品…' : savingGroup ? '正在添加分组…' : savingScene ? '正在添加场景…' : '正在调整顺序…'}}"
  />

</view>
