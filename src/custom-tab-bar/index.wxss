.tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: flex;
  height: calc(82rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  padding: 6rpx 72rpx calc(6rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eeeeee;
  background: rgba(255, 255, 255, 0.98);
}

.tabbar__item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  color: #8a8a8a;
}

.tabbar__item--active {
  color: #111111;
}

.tabbar__icon {
  display: flex;
  width: 34rpx;
  height: 31rpx;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  opacity: 0.56;
}

.tabbar__item--active .tabbar__icon {
  opacity: 1;
}

.tabbar__text {
  font-size: 19rpx;
  font-weight: 500;
  line-height: 1.15;
}
