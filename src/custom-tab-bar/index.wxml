<view class="tabbar">
  <view
    wx:for="{{tabs}}"
    wx:key="pagePath"
    class="tabbar__item {{selected == index ? 'tabbar__item--active' : ''}}"
    data-index="{{index}}"
    bindtap="handleSwitch"
  >
    <view class="tabbar__icon"><app-icon name="{{item.icon}}" size="32" /></view>
    <view class="tabbar__text">{{item.text}}</view>
  </view>
</view>
